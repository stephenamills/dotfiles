[core]
	editor = code --wait
	excludesfile = /Users/steph/.gitignore
	pager = delta

[credential "https://github.com"]
	helper = !gh auth git-credential

[delta]
	hyperlinks = true
	navigate = true

[diff]
	colorMoved = default

[github]
	user = stephenamills

[init]
	defaultBranch = main

[interactive]
	diffFilter = delta --color-only

[merge]
	conflictstyle = diff3

[user]
	name = stephenamills
	email = stephmills468@gmail.com
[lfs "customtransfer.xet"]
	path = git-xet
	args = transfer
	concurrent = true
[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
